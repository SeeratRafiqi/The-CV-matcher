# ============================================
# CV Matcher — Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cv_matcher
DB_USER=cv_matcher_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE=10000

# Authentication
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
SESSION_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# File Uploads
UPLOAD_DIR=./uploads/cvs
MAX_FILE_SIZE=10485760

# Qwen LLM (AI features)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# Optional: set from Alibaba Model Studio pricing doc so admin Usage & Cost matches your bill
# https://www.alibabacloud.com/help/doc-detail/2987148.html
# ALIBABA_LLM_INPUT_PRICE_PER_1M=0.05
# ALIBABA_LLM_OUTPUT_PRICE_PER_1M=0.2
# ALIBABA_TTS_PRICE_PER_10K_CHARS=0.115

# Optional: Alibaba DirectMail — email candidate when a voice interview is assigned
# https://www.alibabacloud.com/help/en/direct-mail/smtp-nodejs
# ALIBABA_DM_FROM=your-verified-sender@yourdomain.com
# ALIBABA_DM_PASS=your_smtp_password
# ALIBABA_DM_FROM_NAME=CV Matcher
# FRONTEND_URL=https://yourdomain.com

# Optional — Auto-initialize database on startup
AUTO_CREATE_DB=false
AUTO_MIGRATE=false
FORCE_RECREATE_TABLES=false
